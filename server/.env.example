# Application
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*
JWT_SECRET=super_secret_jwt_key_change_in_prod

# ═══════ APPWRITE (Auth & KYC) ═══════
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_appwrite_project_id
APPWRITE_API_KEY=your_appwrite_api_key
APPWRITE_DB_ID=crikex_db
APPWRITE_KYC_BUCKET=kyc_documents

# ═══════ CONVEX (Real-Time Betting) ═══════
CONVEX_URL=your_convex_url
# Used by Convex deployment CLI
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# ═══════ NHOST (PostgreSQL & GraphQL) ═══════
NHOST_SUBDOMAIN=your_nhost_subdomain
NHOST_REGION=ap-south-1
NHOST_ADMIN_SECRET=your_nhost_admin_secret

# ═══════ RAZORPAY (Payments) ═══════
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ═══════ TWILIO (SMS OTP Fallback) ═══════
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number
